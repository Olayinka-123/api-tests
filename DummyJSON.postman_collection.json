									"value": "0"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Page 2",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BaseURL}}/users?limit=10&skip;=10",
							"host": [
								"{{BaseURL}}"
							],
							"path": [
