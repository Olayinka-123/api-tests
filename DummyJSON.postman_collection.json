									"value": "10"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Last page_Products",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BaseURL}}/products?limit=10&skip;=200",
							"host": [
								"{{BaseURL}}"
							],
							"path": [
								"products"
							],
							"query": [
								{
									"key": "limit",
									"value": "10"
								},
								{
									"key": "skip;",
									"value": "200"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Limit 0",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BaseURL}}/products?limit=0",
							"host": [
								"{{BaseURL}}"
							],
							"path": [
								"products"
							],
							"query": [
								{
									"key": "limit",
									"value": "0"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Limit 200",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"let res = pm.response.json();\r",
									"let skip = res.skip;\r",
									"let count = res.products.length;\r",
									"let total = res.total;\r",
									"\r",
									"pm.test(\"Last page exact match\", function () {\r",
									"    pm.expect(skip + count).to.eql(total);\r",
									"});"
								],
								"type": "text/javascript",
								"packages": {}
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BaseURL}}/products?limit=200",
							"host": [
								"{{BaseURL}}"
							],
							"path": [
								"products"
							],
							"query": [
								{
									"key": "limit",
									"value": "200"
								}
							]
						}
					},
					"response": []
				}
			],
			"description": "1. GET /users with ?limit=10&skip;=0 — note total in response.\n    \n2. Calculate how many pages exist: Math.ceil(total / 10).\n    \n3. Request page 2: ?limit=10&skip;=10. Verify first ID is different from page 1.\n    \n4. Request the last page — verify products.length may be less than limit.\n    \n5. Try ?limit=0 — what happens? Read DummyJSON docs to understand.\n    \n6. Try ?limit=200 — does it return more than the total? What does limit mean here?\n    \n7. Assert: skip + products.length never exceeds total.  \n    n Goal: Goal: Master pagination testing and boundary conditions."
		}
