				{
					"name": "Refresh Token",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\"username\":\"emilys\",\r\n\"password\":\"emilyspass\"}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{BaseURL}}//auth/refresh",
							"host": [
								"{{BaseURL}}"
							],
							"path": [
								"",
								"auth",
								"refresh"
							]
						}
					},
					"response": []
				}
			],
			"description": "1. POST /auth/login with body {\"username\":\"emilys\",\"password\":\"emilyspass\"}\n    \n2. Save the accessToken from the response as a Postman variable: {{accessToken}}\n    \n3. GET /auth/me with header Authorization: Bearer {{accessToken}} — verify user data.\n    \n4. Try GET /auth/me with NO Authorization header — expect 401.\n    \n5. Try GET /auth/me with Authorization: Bearer badtoken123 — expect 401.\n    \n6. Try POST /auth/login with wrong password 'wrongpass' — document the error response.\n    \n7. POST /auth/refresh with the refreshToken — get a new accessToken.  \n    Goal: Goal: Understand JWT auth flow and test all authentication scenarios."
		},
		{
			"name": "Ex 5_ Pagination Deep Dive",
			"item": [
				{
					"name": "Total",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{BaseURL}}/users?limit=10&skip;=0",
							"host": [
								"{{BaseURL}}"
							],
